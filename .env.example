PROJECT_NAME=banking-lakehouse
ENVIRONMENT=dev
CLOUD_PROVIDER=aws

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
S3_BUCKET=lakehouse
S3_ENDPOINT=http://minio:9000
S3_PATH_STYLE=true

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRANSACTIONS=transactions
KAFKA_TOPIC_CUSTOMERS=customers
KAFKA_TOPIC_EVENTS=events
SCHEMA_REGISTRY_URL=http://schema-registry:8081

AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_AIRFLOW_DB=airflow
POSTGRES_METASTORE_DB=metastore

HIVE_METASTORE_URI=thrift://hive-metastore:9083
TRINO_HOST=trino
TRINO_PORT=8081
TRINO_CATALOG=delta_lake
TRINO_SCHEMA=gold

SPARK_MASTER=local[*]
SPARK_APP_NAME=medallion-lakehouse
SPARK_WAREHOUSE=s3a://lakehouse/warehouse
SPARK_TIMEZONE=UTC
DELTA_LOG_RETENTION_DAYS=30
VACUUM_RETENTION_HOURS=168
LATE_ARRIVAL_WATERMARK_DAYS=45
GOLD_LOOKBACK_DAYS=60

OPENLINEAGE_URL=
OPENLINEAGE_NAMESPACE=banking-lakehouse
SLACK_WEBHOOK_URL=

